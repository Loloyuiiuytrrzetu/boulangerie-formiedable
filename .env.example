# --- Supabase ---
# URL du projet Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
# Clé publique "anon" (exposée au navigateur, protégée par les policies RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon
# Clé "service_role" (SECRÈTE, utilisée uniquement côté serveur pour les
# opérations clients fidélité sans compte : tampons, récompenses, inscription)
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role

# URL publique du site (utilisée pour générer les QR codes)
# En local : http://localhost:3000 — en prod : https://votre-domaine.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
